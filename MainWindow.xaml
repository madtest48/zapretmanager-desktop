<Window x:Class="ZapretManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ZapretManager.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ZapretManager.Models"
        xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1400"
        Height="920"
        MinWidth="1220"
        MinHeight="820"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewMouseMove="Window_PreviewMouseMove"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBgBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Icon="Assets/zapret-manager.ico">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            CornerRadius="14"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#06111C" po:Freeze="False" />
        <SolidColorBrush x:Key="CardBrush" Color="#102235" po:Freeze="False" />
        <SolidColorBrush x:Key="CardBrush2" Color="#0D1C2C" po:Freeze="False" />
        <SolidColorBrush x:Key="CardEdgeBrush" Color="#214A70" po:Freeze="False" />
        <SolidColorBrush x:Key="AccentBrush" Color="#47C78B" po:Freeze="False" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5DD89B" po:Freeze="False" />
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#7BE2B2" po:Freeze="False" />
        <SolidColorBrush x:Key="ActionBrush" Color="#173454" po:Freeze="False" />
        <SolidColorBrush x:Key="ActionHoverBrush" Color="#21476F" po:Freeze="False" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9AB2CD" po:Freeze="False" />
        <SolidColorBrush x:Key="MainTextBrush" Color="#FFFFFF" po:Freeze="False" />
        <SolidColorBrush x:Key="TitleBarBrush" Color="#081725" po:Freeze="False" />
        <SolidColorBrush x:Key="InputBrush" Color="#0A1725" po:Freeze="False" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#2D5379" po:Freeze="False" />
        <SolidColorBrush x:Key="DisabledBrush" Color="#13283F" po:Freeze="False" />
        <SolidColorBrush x:Key="DisabledBorderBrush" Color="#264766" po:Freeze="False" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#8EA6C2" po:Freeze="False" />
        <SolidColorBrush x:Key="SelectionBrush" Color="#35506A" po:Freeze="False" />
        <SolidColorBrush x:Key="InnerCardBrush" Color="#0C1A28" po:Freeze="False" />
        <SolidColorBrush x:Key="InnerCardBorderBrush" Color="#2C5478" po:Freeze="False" />
        <SolidColorBrush x:Key="TooltipBackgroundBrush" Color="#102235" po:Freeze="False" />
        <SolidColorBrush x:Key="TooltipBorderBrush" Color="#31597F" po:Freeze="False" />
        <SolidColorBrush x:Key="TooltipTextBrush" Color="#EAF3FC" po:Freeze="False" />
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#102235" po:Freeze="False" />
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#4A6A86" po:Freeze="False" />
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#5B7C98" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeSuccessBackgroundBrush" Color="#27423D" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeSuccessBorderBrush" Color="#6C9184" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeSuccessForegroundBrush" Color="#7FE0B4" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgePartialBackgroundBrush" Color="#4A422E" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgePartialBorderBrush" Color="#A89566" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgePartialForegroundBrush" Color="#E3C168" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeFailureBackgroundBrush" Color="#4F3537" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeFailureBorderBrush" Color="#B88484" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeFailureForegroundBrush" Color="#E6B3B1" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralBackgroundBrush" Color="#0C1A28" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralBorderBrush" Color="#274A6B" po:Freeze="False" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralForegroundBrush" Color="#9AB2CD" po:Freeze="False" />
        <SolidColorBrush x:Key="SummarySuccessBadgeBrush" Color="#27423D" po:Freeze="False" />
        <SolidColorBrush x:Key="SummarySuccessBadgeBorderBrush" Color="#6C9184" po:Freeze="False" />
        <SolidColorBrush x:Key="SummarySuccessBadgeIconBrush" Color="#7FE0B4" po:Freeze="False" />
        <SolidColorBrush x:Key="SummaryPartialBadgeBrush" Color="#4A422E" po:Freeze="False" />
        <SolidColorBrush x:Key="SummaryPartialBadgeBorderBrush" Color="#A89566" po:Freeze="False" />
        <SolidColorBrush x:Key="SummaryPartialBadgeIconBrush" Color="#E3C168" po:Freeze="False" />
        <SolidColorBrush x:Key="SummaryFailureBadgeBrush" Color="#4F3537" po:Freeze="False" />
        <SolidColorBrush x:Key="SummaryFailureBadgeBorderBrush" Color="#B88484" po:Freeze="False" />
        <SolidColorBrush x:Key="SummaryFailureBadgeIconBrush" Color="#E6B3B1" po:Freeze="False" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#102235" po:Freeze="False" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#102235" po:Freeze="False" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#35506A" po:Freeze="False" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" po:Freeze="False" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#35506A" po:Freeze="False" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" po:Freeze="False" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="19" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,3" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="650" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="Background" Value="{DynamicResource DisabledBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#0A2416" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PresetButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,2" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style x:Key="TitleBarThemeButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="MenuHostButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="12,2" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MiniIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.4" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ActionHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,5,12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource ActionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource SelectionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HoverBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBorder" Property="Background" Value="{DynamicResource ActionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="650" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="MaxDropDownHeight" Value="180" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="650" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="34" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  ClickMode="Press"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Style="{DynamicResource ComboToggleButtonStyle}"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0" />
                                    <ContentPresenter Margin="10,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      IsHitTestVisible="False" />
                                    <Border Grid.Column="1"
                                            x:Name="DropDownBorder"
                                            Background="{DynamicResource DisabledBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1,0,0,0"
                                            CornerRadius="0,5,5,0"
                                            IsHitTestVisible="False">
                                        <Path Width="10"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                            Fill="{DynamicResource MainTextBrush}"
                                              Data="M 0 0 L 10 0 L 5 6 Z" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DropDownBorder" Property="Background" Value="{DynamicResource ActionBrush}" />
                                <Setter TargetName="DropDownBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter TargetName="DropDownBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComboToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"
                                CornerRadius="6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="0"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollContentPresenter}}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ActionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource TooltipBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TooltipTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TooltipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="StaysOpen" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource CardBrush2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Margin="12,6"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="0,1,0,0"
                                Opacity="0.7" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"
                                                  ContentSource="Header" />
                                <TextBlock x:Name="CheckGlyph"
                                           Grid.Column="1"
                                           Text="✓"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MainTextBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="{DynamicResource ActionBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                <Setter TargetName="MenuItemBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollTrackBrush}" />
            <Setter Property="Width" Value="4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="4" />
                    <Setter Property="Width" Value="Auto" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="650" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="{DynamicResource InputBrush}"
                                    BorderBrush="{DynamicResource InputBorderBrush}"
                                    BorderThickness="1" />
                            <Path x:Name="CheckMark"
                                  Grid.Column="0"
                                  Width="10"
                                  Height="7"
                                  Data="M 1 3.5 L 4 6.5 L 9 1"
                                  Stroke="#0A2416"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="{DynamicResource CardBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource CardBrush2}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="TextBlock.TextAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBrush}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsKeyboardFocusWithin" Value="True" />
                        <Condition Property="IsSelected" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBrush}" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowRootBorder"
            Background="{DynamicResource AppBgBrush}"
            BorderThickness="0"
            CornerRadius="14"
            ClipToBounds="True"
            SnapsToDevicePixels="True">
        <Grid x:Name="WindowRootGrid" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image Width="18" Height="18" Source="Assets/zapret-manager.ico" Stretch="Uniform" />
                        <TextBlock Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MainTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="{Binding WindowTitle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,4,10,4">
                        <TextBlock Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11.5"
                                   Text="{Binding ManagerVersionLabel}" />
                        <Button Content="◐"
                                Style="{StaticResource TitleBarThemeButtonStyle}"
                                Click="ThemeButton_Click"
                                ToolTip="Переключить светлую и тёмную тему." />
                        <Border Background="Transparent"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="━" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" ToolTip="Свернуть окно" />
                                <Button Content="▢" Style="{StaticResource WindowControlButtonStyle}" Click="MaximizeButton_Click" ToolTip="Развернуть или восстановить окно" />
                                <Button Content="✕" Style="{StaticResource WindowControlButtonStyle}" Click="CloseButton_Click" ToolTip="Закрыть окно" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource CardBrush2}"
                    BorderBrush="{DynamicResource CardEdgeBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="12,3,0,3">
                    <Button Content="Списки"
                            Style="{StaticResource MenuHostButtonStyle}"
                            Click="MenuHostButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Включённые домены" Command="{Binding OpenIncludedDomainsEditorCommand}" />
                                <MenuItem Header="Исключённые домены" Command="{Binding OpenExcludedDomainsEditorCommand}" />
                                <MenuItem Header="Системный hosts" Command="{Binding OpenHostsEditorCommand}" />
                                <MenuItem Header="Цели для проверки (targets.txt)" Command="{Binding OpenTargetsFileCommand}" />
                                <Separator />
                                <MenuItem Header="Пользовательские подсети (IPSet)" Command="{Binding OpenUserSubnetsEditorCommand}" />
                                <Separator />
                                <MenuItem Header="Скрытые конфиги..." Command="{Binding OpenHiddenConfigsCommand}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Button Content="Инструменты"
                            Style="{StaticResource MenuHostButtonStyle}"
                            Click="MenuHostButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Режим IPSet..." Command="{Binding OpenIpSetModeCommand}" />
                                <MenuItem Header="Настройка DNS-адреса" Command="{Binding OpenDnsSettingsCommand}" />
                                <MenuItem Header="Диагностика системы..." Command="{Binding OpenDiagnosticsCommand}" />
                                <MenuItem Header="Обновить список IPSet" Command="{Binding UpdateIpSetListCommand}" />
                                <MenuItem Header="Обновить hosts для zapret" Command="{Binding UpdateHostsFileCommand}" />
                                <Separator />
                                <MenuItem Header="Очистить кэш Discord" Command="{Binding ClearDiscordCacheCommand}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Button Content="Настройки"
                            Style="{StaticResource MenuHostButtonStyle}"
                            Click="MenuHostButton_Click"
                            ToolTip="Настройки автозапуска, трея и обновлений.">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Автопроверка обновлений"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding AutoCheckUpdatesEnabled, Mode=TwoWay}" />
                                <MenuItem Header="При закрытии в трей"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding CloseToTrayEnabled, Mode=TwoWay}" />
                                <MenuItem Header="Автозапуск с Windows"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding StartWithWindowsEnabled, Mode=TwoWay}" />
                                <MenuItem Header="Сворачивать в трей"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding MinimizeToTrayEnabled, Mode=TwoWay}" />
                                <Separator />
                                <MenuItem Header="Откатить сборку"
                                          Command="{Binding RestorePreviousVersionCommand}" />
                                <MenuItem Header="Проверить обновление программы"
                                          Command="{Binding CheckManagerUpdateCommand}" />
                                <MenuItem Header="Удалить программу"
                                          Command="{Binding UninstallProgramCommand}" />
                                <Separator />
                                <MenuItem Header="О программе..."
                                          Command="{Binding OpenAboutCommand}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Сборка" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding InstallationPath}" Style="{StaticResource MutedTextStyle}" />
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" Content="Обновить" Margin="0" MinWidth="0" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButtonStyle}" ToolTip="Перечитать текущую папку zapret и обновить статусы." />
                                <Button Grid.Row="0" Grid.Column="2" Content="Поиск zapret" Margin="0" MinWidth="0" Command="{Binding QuickSearchCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Быстро найти zapret в типичных местах на компьютере." />
                                <Button Grid.Row="2" Grid.Column="0" Content="Выбрать папку" Margin="0" MinWidth="0" Command="{Binding BrowseCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Выбрать рабочую папку zapret вручную." />
                                <Button Grid.Row="2" Grid.Column="2" Content="Открыть" Margin="0" MinWidth="0" Command="{Binding OpenFolderCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Открыть текущую папку zapret в проводнике." />
                                <Button Grid.Row="4" Grid.Column="0" Content="Скачать zapret" Margin="0" MinWidth="0" Command="{Binding DownloadZapretCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Скачать свежую сборку zapret в выбранную папку." />
                    <Button Grid.Row="4" Grid.Column="2" Content="Удалить zapret" Margin="0" MinWidth="0" Command="{Binding DeleteZapretCommand}" Style="{StaticResource ActionButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip MaxWidth="260">
                                <TextBlock TextWrapping="Wrap"
                                           MaxWidth="240"
                                           LineHeight="15"
                                           Text="Остановить процессы, удалить службу и удалить текущую и предыдущую сборку zapret." />
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                                <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Content="Автоматический режим" Margin="0" MinWidth="0" Command="{Binding AutoInstallCommand}" Style="{StaticResource PrimaryButtonStyle}">
                                    <Button.ToolTip>
                                        <ToolTip MaxWidth="260">
                                            <TextBlock TextWrapping="Wrap"
                                                       MaxWidth="240"
                                                       LineHeight="15"
                                                       Text="Если сборка уже выбрана, программа проверит конфиги и поставит лучший вариант как службу. Если сборки нет, сначала скачает свежий zapret." />
                                        </ToolTip>
                                    </Button.ToolTip>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Состояние" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding VersionText}" Foreground="{DynamicResource MainTextBrush}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding RuntimeStatus}" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding ServiceStatus}" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding UpdateStatus}" Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Panel.ZIndex="20"
                            Margin="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="14"
                            Opacity="0.985"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="0.2"
                                              Color="#203347" />
                        </Border.Effect>
                        <StackPanel Margin="14,12,14,14">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="10"
                                        Height="10"
                                        CornerRadius="5"
                                        Background="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentHoverBrush}"
                                        BorderThickness="1"
                                        Margin="0,0,8,0" />
                                <TextBlock Text="Идёт операция"
                                           Foreground="{DynamicResource MainTextBrush}"
                                           FontSize="14.5"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <ProgressBar Margin="0,12,0,12"
                                         Height="7"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding BusyProgressValue}"
                                         IsIndeterminate="{Binding BusyProgressIsIndeterminate}" />
                            <TextBlock Text="{Binding BusyActionText}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding BusyEtaText}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding RuntimeStatus}"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="16,14,16,14">
                        <Grid>
                            <StackPanel>
                            <TextBlock Text="Служба и обновление" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Игровой режим"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <Grid Margin="0,8,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding GameModeOptions}"
                                          SelectedItem="{Binding SelectedGameMode}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          ToolTip="Режим обработки игровых портов. Обычно выбирают TCP + UDP." />
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Content="Применить"
                                        Command="{Binding ApplyGameModeCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Сохранить игровой режим&#10;и перезапустить активный профиль или службу." />
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource CardEdgeBrush}" Margin="0,10,0,10" />

                            <TextBlock Text="Служба"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />

                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                <Button Content="Установить службу"
                                        Margin="0"
                                        MinWidth="0"
                                        Command="{Binding InstallServiceCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Установить выбранный конфиг&#10;как службу Windows с автозапуском." />
                                <Button Content="Удалить службу"
                                        Margin="8,0,0,0"
                                        MinWidth="0"
                                        Command="{Binding RemoveServiceCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="Удалить службу zapret&#10;и остановить её, если она запущена." />
                            </UniformGrid>

                            <Rectangle Height="1" Fill="{DynamicResource CardEdgeBrush}" Margin="0,6,0,8" />

                            <TextBlock Text="Обновление"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />

                            <Grid Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Row="0"
                                        Grid.Column="0"
                                        Content="Проверить обновл."
                                        Margin="0"
                                        MinWidth="0"
                                        Command="{Binding CheckUpdatesCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="Проверить, вышла ли новая версия сборки." />
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Content="Обновить сборку"
                                        Margin="8,0,0,0"
                                        MinWidth="0"
                                        Command="{Binding ApplyUpdateCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Скачать и установить новую версию сборки." />
                            </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Panel.ZIndex="26"
                            Margin="12,0,12,12"
                            Padding="12,10"
                            MaxHeight="176"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            CornerRadius="12"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Background" Value="{DynamicResource CardBrush2}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource CardEdgeBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInlineNotificationVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsInlineNotificationError}" Value="True">
                                        <Setter Property="Background" Value="#4A2430" />
                                        <Setter Property="BorderBrush" Value="#D08AA8" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="2"
                                    Background="{DynamicResource AccentBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInlineNotificationError}" Value="True">
                                                <Setter Property="Background" Value="#E08CAD" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <ScrollViewer Grid.Column="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="True">
                                <TextBlock Text="{Binding InlineNotificationText}"
                                           Foreground="{DynamicResource MainTextBrush}"
                                           FontSize="12.6"
                                           FontWeight="SemiBold"
                                           LineHeight="18"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Проверка конфигов" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Один общий список конфигов. Проверка считает сайты из targets.txt, а ping остаётся как отдельная диагностика."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,14,0,14"
                                Padding="14"
                                CornerRadius="12"
                                Background="{DynamicResource CardBrush2}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Быстрые цели" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" FontSize="13" />
                                <WrapPanel Margin="0,12,0,6">
                                        <Button Content="Все цели" Command="{Binding UseDefaultTargetsCommand}" Style="{StaticResource PresetButtonStyle}" ToolTip="Проверять все стандартные адреса из targets.txt." />
                                        <Button Content="YouTube" Command="{Binding UseYouTubePresetCommand}" Style="{StaticResource PresetButtonStyle}" />
                                        <Button Content="Discord" Command="{Binding UseDiscordPresetCommand}" Style="{StaticResource PresetButtonStyle}" />
                                        <Button Content="Cloudflare" Command="{Binding UseCloudflarePresetCommand}" Style="{StaticResource PresetButtonStyle}" />
                                </WrapPanel>
                                <TextBlock Text="{Binding DefaultTargetsHint}" Style="{StaticResource MutedTextStyle}" />
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="ManualTargetTextBox"
                                                 Text="{Binding ManualTarget, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Можно указать свои домены или URL через запятую." />
                                        <TextBlock Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   IsHitTestVisible="False"
                                                   Text="Все цели">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ManualTarget}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ManualTarget}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ElementName=ManualTargetTextBox, Path=IsKeyboardFocused}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Button Grid.Column="1"
                                            Margin="10,0,0,0"
                                            MinWidth="176"
                                            Content="Проверить выбранный"
                                            Command="{Binding RunSelectedTestCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            ToolTip="Проверить только выбранный в таблице конфиг&#10;по выбранным адресам." />
                                    <Button Grid.Column="2"
                                            Margin="8,0,0,0"
                                            MinWidth="140"
                                            Content="{Binding ProbeButtonText}"
                                            Command="{Binding RunTestsCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            ToolTip="Запустить проверку всех видимых конфигов&#10;по выбранным адресам." />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,0,0,14"
                                Padding="12"
                                CornerRadius="12"
                                Background="{DynamicResource InnerCardBrush}"
                                BorderBrush="{DynamicResource InnerCardBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                            <TextBlock Text="Результат" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding RecommendedConfigText}"
                                       Foreground="{DynamicResource AccentBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SelectedConfig.Name, TargetNullValue=Конфиг не выбран}"
                                       Foreground="{DynamicResource MainTextBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SelectedSummaryText}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12.5"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <UniformGrid Grid.Column="1" Columns="3" VerticalAlignment="Center">
                                    <Button Content="Запустить выбранный"
                                            Margin="0,0,10,0"
                                            MinWidth="0"
                                            Command="{Binding StartCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            ToolTip="Запустить выбранный конфиг скрыто, без cmd-окна." />
                                    <Button Content="Остановить"
                                            Margin="0,0,10,0"
                                            MinWidth="0"
                                            Command="{Binding StopCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            ToolTip="Остановить вручную запущенный профиль.&#10;Установленная служба этой кнопкой не трогается." />
                                    <Button Content="Скрыть выбранный"
                                            Margin="0,0,0,0"
                                            MinWidth="0"
                                            Command="{Binding HideSelectedConfigCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            ToolTip="Убрать выбранный конфиг из основного списка&#10;и исключить его из проверки." />
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource ActionBrush}"
                                    BorderBrush="{DynamicResource CardEdgeBrush}"
                                    BorderThickness="1,1,1,0"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="270" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,1,1">
                                        <Button Content="Конфиг"
                                                Tag="ConfigName"
                                                Click="ConfigHeaderSortButton_Click"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,1,1">
                                        <Button Content="Доступно"
                                                Tag="SortSuccessValue"
                                                Click="ConfigHeaderSortButton_Click"
                                                HorizontalContentAlignment="Center"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                    <Border Grid.Column="2"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,1,1">
                                        <Button Content="Отклик, мс"
                                                Tag="AveragePingMilliseconds"
                                                Click="ConfigHeaderSortButton_Click"
                                                HorizontalContentAlignment="Center"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                    <Border Grid.Column="3"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Button Content="Сводка"
                                                Tag="Summary"
                                                Click="ConfigHeaderSortButton_Click"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      x:Name="ConfigGrid"
                                      ItemsSource="{Binding ConfigRows}"
                                      SelectedItem="{Binding SelectedConfigRow}"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      SelectionChanged="ConfigGrid_SelectionChanged"
                                      CanUserResizeColumns="False"
                                      HeadersVisibility="None"
                                      BorderThickness="1,0,1,1"
                                      Sorting="ConfigGrid_Sorting">
                                <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Конфиг" Width="270" SortMemberPath="ConfigName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="12,3,4,3">
                        <TextBlock Text="{Binding ConfigName}" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11.5" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Доступно"
                                                        Width="110"
                                                        SortMemberPath="SortSuccessValue">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding SuccessCountText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Отклик, мс"
                                                        Width="110"
                                                        SortMemberPath="AveragePingMilliseconds">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding ResponseText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Сводка" Width="*" SortMemberPath="Summary">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,0,2,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <DockPanel LastChildFill="True"
                                                           Margin="0,0,4,0">
                                                <controls:ProbeStatusBadge BadgeText="{Binding SummaryBadgeText}"
                                                                           Margin="0,0,8,0"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Center">
                                                    <controls:ProbeStatusBadge.Style>
                                                        <Style TargetType="controls:ProbeStatusBadge">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasProbeResult}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </controls:ProbeStatusBadge.Style>
                                                </controls:ProbeStatusBadge>
                                                <TextBlock Text="{Binding SummaryBodyText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,2,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SummaryBodyText}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                </DockPanel>
                                                <Button Grid.Column="1"
                                                        Click="ProbeDetailsButton_Click"
                                                        Tag="{Binding}"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Подробные результаты проверки">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource MiniIconButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding HasProbeResult}" Value="True" />
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Path Width="12"
                                                          Height="12"
                                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                          StrokeThickness="1.45"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Data="M 3 1.8 H 8.4 L 11.2 4.6 V 11.2 H 3 Z M 8.2 1.8 V 4.8 H 11.2 M 5.1 6.6 H 9.2 M 5.1 8.5 H 9.2" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
