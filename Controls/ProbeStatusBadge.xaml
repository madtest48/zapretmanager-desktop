<UserControl x:Class="ZapretManager.Controls.ProbeStatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="Auto"
             Height="Auto"
             Background="Transparent"
             Focusable="False"
             IsHitTestVisible="False">
    <Border x:Name="BadgeBorder"
            MinWidth="28"
            Height="20"
            Padding="4,0"
            CornerRadius="4"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ProbeBadgeSuccessBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProbeBadgeSuccessBorderBrush}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="!">
                        <Setter Property="Background" Value="{DynamicResource ProbeBadgePartialBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ProbeBadgePartialBorderBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="DNS">
                        <Setter Property="Background" Value="{DynamicResource ProbeBadgePartialBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ProbeBadgePartialBorderBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="✕">
                        <Setter Property="Background" Value="{DynamicResource ProbeBadgeFailureBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ProbeBadgeFailureBorderBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="—">
                        <Setter Property="Background" Value="{DynamicResource ProbeBadgeNeutralBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ProbeBadgeNeutralBorderBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Width="Auto"
              Height="10"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              SnapsToDevicePixels="True">
            <Path Data="M 1.2 5.2 L 3.9 7.8 L 8.8 2"
                  Stretch="None"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Stroke="{DynamicResource ProbeBadgeSuccessForegroundBrush}"
                  StrokeThickness="1.8"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  SnapsToDevicePixels="True">
                <Path.Style>
                    <Style TargetType="Path">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="✓">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Path.Style>
            </Path>

            <Path Data="M 2 2 L 8 8 M 8 2 L 2 8"
                  Stretch="None"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Stroke="{DynamicResource ProbeBadgeFailureForegroundBrush}"
                  StrokeThickness="1.7"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  SnapsToDevicePixels="True">
                <Path.Style>
                    <Style TargetType="Path">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="✕">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Path.Style>
            </Path>

            <Grid Width="10"
                  Height="10"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  SnapsToDevicePixels="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="!">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Rectangle Width="1.8"
                           Height="5.2"
                           RadiusX="1"
                           RadiusY="1"
                           Fill="{DynamicResource ProbeBadgePartialForegroundBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0.8,0,0"
                           SnapsToDevicePixels="True" />
                <Ellipse Width="1.8"
                         Height="1.8"
                         Fill="{DynamicResource ProbeBadgePartialForegroundBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,0.7"
                         SnapsToDevicePixels="True" />
            </Grid>

            <Rectangle Width="5.4"
                       Height="1.4"
                       RadiusX="0.7"
                       RadiusY="0.7"
                       Fill="{DynamicResource ProbeBadgeNeutralForegroundBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       SnapsToDevicePixels="True">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="—">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <TextBlock Text="{Binding BadgeText, ElementName=Root}"
                       Foreground="{DynamicResource ProbeBadgePartialForegroundBrush}"
                       FontSize="8"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       SnapsToDevicePixels="True">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="DNS">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

</UserControl>
