<Window x:Class="ZapretManager.ProbeDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ZapretManager.Controls"
        Title="Подробности проверки"
        Width="Auto"
        MinWidth="560"
        MaxWidth="760"
        MaxHeight="640"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#102235" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#295276" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9AB2CD" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0C1A28" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#274A6B" />
        <SolidColorBrush x:Key="ActionBrush" Color="#173454" />
        <SolidColorBrush x:Key="ActionBorderBrush" Color="#31597F" />
        <SolidColorBrush x:Key="GridRowBrush" Color="#102235" />
        <SolidColorBrush x:Key="GridAltRowBrush" Color="#0D1C2C" />

        <SolidColorBrush x:Key="SummarySuccessBrush" Color="#27423D" />
        <SolidColorBrush x:Key="SummarySuccessBorderBrush" Color="#6C9184" />
        <SolidColorBrush x:Key="SummarySuccessIconBrush" Color="#7FE0B4" />
        <SolidColorBrush x:Key="SummaryPartialBrush" Color="#4A422E" />
        <SolidColorBrush x:Key="SummaryPartialBorderBrush" Color="#A89566" />
        <SolidColorBrush x:Key="SummaryPartialIconBrush" Color="#E3C168" />
        <SolidColorBrush x:Key="SummaryFailureBrush" Color="#4F3537" />
        <SolidColorBrush x:Key="SummaryFailureBorderBrush" Color="#B88484" />
        <SolidColorBrush x:Key="SummaryFailureIconBrush" Color="#E6B3B1" />

        <SolidColorBrush x:Key="ProbeBadgeSuccessBackgroundBrush" Color="#27423D" />
        <SolidColorBrush x:Key="ProbeBadgeSuccessBorderBrush" Color="#6C9184" />
        <SolidColorBrush x:Key="ProbeBadgeSuccessForegroundBrush" Color="#7FE0B4" />
        <SolidColorBrush x:Key="ProbeBadgePartialBackgroundBrush" Color="#4A422E" />
        <SolidColorBrush x:Key="ProbeBadgePartialBorderBrush" Color="#A89566" />
        <SolidColorBrush x:Key="ProbeBadgePartialForegroundBrush" Color="#E3C168" />
        <SolidColorBrush x:Key="ProbeBadgeFailureBackgroundBrush" Color="#4F3537" />
        <SolidColorBrush x:Key="ProbeBadgeFailureBorderBrush" Color="#B88484" />
        <SolidColorBrush x:Key="ProbeBadgeFailureForegroundBrush" Color="#E6B3B1" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralBackgroundBrush" Color="#0C1A28" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralBorderBrush" Color="#274A6B" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralForegroundBrush" Color="#9AB2CD" />

        <SolidColorBrush x:Key="SuccessTextBrush" Color="#7FE0B4" />
        <SolidColorBrush x:Key="PartialTextBrush" Color="#E3C168" />
        <SolidColorBrush x:Key="FailureTextBrush" Color="#E6A6B8" />
        <SolidColorBrush x:Key="NeutralTextBrush" Color="#9AB2CD" />
        <SolidColorBrush x:Key="PingTextBrush" Color="#96D6E8" />
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#102235" />
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#4A6A86" />
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#5B7C98" />
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="{DynamicResource GridRowBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltRowBrush}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollTrackBrush}" />
            <Setter Property="Width" Value="4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="4" />
                                <Setter Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="ToolTip" Value="{Binding RowToolTip}" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.18"
                              Color="#172838" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="20"
                               FontWeight="Medium" />
                    <TextBlock x:Name="SubtitleTextBlock"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12"
                               Visibility="Collapsed" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource ChromeButtonStyle}"
                        Content="×"
                        FontSize="18"
                        Click="CloseButton_Click" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,10"
                    Padding="16,14"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="SummaryBadgeBorder"
                            Width="34"
                            Height="34"
                            CornerRadius="9"
                            BorderThickness="1">
                        <Grid Width="16"
                              Height="16"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Path x:Name="SummarySuccessPath"
                                  Data="M 1.5 8 L 5.7 12 L 14.3 2.5"
                                  Stroke="{DynamicResource SummarySuccessIconBrush}"
                                  StrokeThickness="2.3"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />
                            <Path x:Name="SummaryFailurePath"
                                  Data="M 3 3 L 13 13 M 13 3 L 3 13"
                                  Stroke="{DynamicResource SummaryFailureIconBrush}"
                                  StrokeThickness="2.1"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed" />
                            <Grid x:Name="SummaryPartialGrid"
                                  Width="16"
                                  Height="16"
                                  Visibility="Collapsed">
                                <Rectangle Width="2.2"
                                           Height="8"
                                           RadiusX="1"
                                           RadiusY="1"
                                           Fill="{DynamicResource SummaryPartialIconBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,1.4,0,0" />
                                <Ellipse Width="2.2"
                                         Height="2.2"
                                         Fill="{DynamicResource SummaryPartialIconBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Bottom"
                                         Margin="0,0,0,1.2" />
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="SummaryTextBlock"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13.5"
                                   FontWeight="Medium" />
                        <TextBlock x:Name="StatsTextBlock"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="11.5"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  Margin="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource ActionBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1,1,1,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="14,5,10,5">
                            <TextBlock Text="Цель"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12.8"
                                       FontWeight="Medium" />
                        </Border>
                        <Border Grid.Column="1"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="0,5">
                            <TextBlock Text="HTTP"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12.8"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="2"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="0,5">
                            <TextBlock Text="TLS 1.2"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12.8"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="3"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="0,5">
                            <TextBlock Text="TLS 1.3"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12.8"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="4"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="0,5">
                            <TextBlock Text="Ping"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12.8"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="5"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="0,5" />
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          MaxHeight="430"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          AlternationCount="2"
                          HeadersVisibility="None"
                          BorderThickness="1,0,1,1"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Цель" Width="260">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TargetName}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12.6"
                                               FontWeight="Normal"
                                               FontFamily="Consolas"
                                               Margin="12,0,4,0"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="HTTP" Width="72">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Http.Text}"
                                               Foreground="{Binding Http.Foreground}"
                                               FontSize="11.8"
                                               FontWeight="Normal"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Http.Tooltip}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="TLS 1.2" Width="78">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Tls12.Text}"
                                               Foreground="{Binding Tls12.Foreground}"
                                               FontSize="11.8"
                                               FontWeight="Normal"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Tls12.Tooltip}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="TLS 1.3" Width="78">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Tls13.Text}"
                                               Foreground="{Binding Tls13.Foreground}"
                                               FontSize="11.8"
                                               FontWeight="Normal"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Tls13.Tooltip}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Ping" Width="78">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PingText}"
                                               Foreground="{Binding PingBrush}"
                                               FontSize="11.8"
                                               FontWeight="Normal"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding PingToolTip}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="52">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:ProbeStatusBadge BadgeText="{Binding DetailText}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               ToolTip="{Binding RowToolTip}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

        </Grid>
    </Border>
</Window>
