<Application x:Class="ZapretManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <sys:Double x:Key="{x:Static SystemParameters.VerticalScrollBarWidthKey}">4</sys:Double>
        <sys:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarHeightKey}">4</sys:Double>
        <sys:Double x:Key="{x:Static SystemParameters.VerticalScrollBarButtonHeightKey}">0</sys:Double>
        <sys:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarButtonWidthKey}">0</sys:Double>
        <SolidColorBrush x:Key="TooltipBackgroundBrush" Color="#102235" />
        <SolidColorBrush x:Key="TooltipBorderBrush" Color="#31597F" />
        <SolidColorBrush x:Key="TooltipTextBrush" Color="#EAF3FC" />
        <Style TargetType="ToolTip">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap" />
                    <Setter Property="Foreground" Value="{DynamicResource TooltipTextBrush}" />
                    <Setter Property="MaxWidth" Value="240" />
                    <Setter Property="LineHeight" Value="15" />
                </Style>
            </Style.Resources>
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="{DynamicResource TooltipBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TooltipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TooltipTextBrush}" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="FontSize" Value="11.6" />
            <Setter Property="MaxWidth" Value="260" />
            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="{DynamicResource TooltipTextBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="15"
                                   MaxWidth="240" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
